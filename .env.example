# Database (Neon PostgreSQL)
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js — generate with: npx auth secret
BETTER_AUTH_SECRET=ac14f467e6d5e269303f94f2c419266e8f57e0b3029b465e3403f491039caf3d

# GitHub OAuth
# https://github.com/settings/developers → OAuth Apps
# Callback: https://your-domain.com/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
# Callback: https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
